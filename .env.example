# OpenAI API Key (Required)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# LangSmith (Optional - for tracing and monitoring)
# Get from: https://smith.langchain.com/settings
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_TRACING=true

# Brave Search API (Required for spending assistant)
# Get from: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# PostgreSQL Database (Required for supervisor and spending agents)
# Default matches docker-compose.yaml configuration
POSTGRES_DB_URL=postgresql://root:123qwe@localhost:5432/ai

# MCP Database Toolbox (Required for spending assistant)
# Must be running on port 5000 - see README for setup instructions
MCP_DB_TOOLBOX_URL=http://localhost:5000/mcp

# Coding Agent (Claude Code-like deepagents agent) - all optional, defaults shown
# Absolute path to the project the agent operates on. Defaults to this repo root.
CODING_AGENT_PROJECT_DIR=
# Main model id and reasoning effort (low | medium | high)
CODING_AGENT_MODEL=gpt-5.5
CODING_AGENT_REASONING_EFFORT=medium
# Model for the read-only Explore investigation subagent
CODING_AGENT_EXPLORE_MODEL=gpt-5.4-nano
